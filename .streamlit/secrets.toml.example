# ─── INSTRUCTIONS ─────────────────────────────────────────────────────────────
# For LOCAL dev:  copy this file to .streamlit/secrets.toml and fill in values.
# For STREAMLIT CLOUD: paste these key=value pairs into the Secrets section
#   of your app settings at share.streamlit.io (no file needed).
# ──────────────────────────────────────────────────────────────────────────────

# Access control — users must enter this password to use the app.
# Remove or leave blank to disable the password gate (open access).
APP_PASSWORD = "your-password-here"

# LLM — Groq (free tier, recommended)
# Get a free key at: https://console.groq.com
LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_..."
GROQ_MODEL = "llama-3.3-70b-versatile"

# Optional: switch to Anthropic instead
# LLM_PROVIDER = "anthropic"
# ANTHROPIC_API_KEY = "sk-ant-..."
# ANTHROPIC_MODEL = "claude-haiku-4-5-20251001"
