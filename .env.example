# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: "anthropic" | "openai" | "ollama"
LLM_PROVIDER=anthropic

# Anthropic (recommended for cloud hosting)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (alternative)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local only — not suitable for web hosting)
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:3b-instruct
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ─── Backend URL (used by the Streamlit frontend) ────────────────────────────
# Set this to the public URL of your FastAPI backend when deploying.
# Leave blank to use the default localhost for local development.
BACKEND_URL=http://127.0.0.1:8000

# ─── App settings ────────────────────────────────────────────────────────────
DEBUG=false
LLM_TIMEOUT_SECONDS=60

# ─── Vector store / document paths ──────────────────────────────────────────
VECTOR_STORE_PATH=data/vector_store
DOCUMENTS_DIR=data/documents
