# ===== local dev: FastAPI only =====
# Your inference endpoint must be OpenAI-compatible.
DEBUG=True

# Example:
# - local vLLM:  http://127.0.0.1:8001/v1
# - remote API:  http://YOUR_SERVER_IP:8001/v1
VLLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_MODEL=my-inference-model
LLM_API_KEY=

LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Optional: Redis-backed session memory (recommended for persistence)
REDIS_URL=redis://127.0.0.1:6379/0
STATE_TTL_SECONDS=604800
REDIS_KEY_PREFIX=nih_chatbot

# Hybrid memory tuning
SHORT_TERM_LIMIT=20
SUMMARY_THRESHOLD=10
SUMMARY_REFRESH_EVERY_TURNS=6
LONG_TERM_MEMORY_WINDOW=50
LONG_TERM_MEMORY_MAX_LINES=8
MEMORY_CONTEXT_MAX_CHARS=6000

VECTOR_STORE_PATH=data/vector_store
DOCUMENTS_DIR=data/documents
