# ===== FastAPI app =====
DEBUG=False
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000
REDIS_URL=redis://127.0.0.1:6379/0
STATE_TTL_SECONDS=604800
REDIS_KEY_PREFIX=nih_chatbot
SHORT_TERM_LIMIT=20
SUMMARY_THRESHOLD=10
SUMMARY_REFRESH_EVERY_TURNS=6
LONG_TERM_MEMORY_WINDOW=50
LONG_TERM_MEMORY_MAX_LINES=8
MEMORY_CONTEXT_MAX_CHARS=6000

# ===== vLLM server =====
# 方式A（推荐，直接加载你本地训练权重）:
# 1) 把权重放在宿主机目录 LOCAL_MODEL_DIR 下，比如:
#    LOCAL_MODEL_DIR=/opt/models
#    /opt/models/my-ft-model/{config.json, tokenizer.json, *.safetensors ...}
# 2) 设置 VLLM_MODEL=/models/my-ft-model
#
# 方式B（在线拉取 Hugging Face 模型）:
#    VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_MODEL=/models/my-ft-model
VLLM_SERVED_MODEL_NAME=qwen2.5-7b-instruct
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.9

# Optional if your model access requires auth
HUGGING_FACE_HUB_TOKEN=
LOCAL_MODEL_DIR=./models

# ===== project paths =====
VECTOR_STORE_PATH=data/vector_store
DOCUMENTS_DIR=data/documents
